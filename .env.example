# fsa-agent Environment Configuration
# Copy this to .env and fill in your values

# Parent domain for iframe (e.g., https://learning.fullsteamahead.ca)
PARENT_DOMAIN=https://my.fullsteamahead.ca

# PostgreSQL Connection
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fsa_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# AI Service (OpenRouter) — REQUIRED
# The tutor agent always calls the LLM; the app will not function without this key.
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6-20250515

# Python AI service URL (used by Express to forward chat requests)
PYTHON_SERVICE_URL=http://ai-service:5000